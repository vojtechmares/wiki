---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import GridLayout from "../../components/GridLayout.astro";
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "../../components/ui/card";
import { PageBreadcrumb } from "../../components/PageBreadcrumb";
import { getIncidents } from "../../lib/collections";
import { Badge } from "../../components/ui/badge";
import { SEVERITY_COLORS } from "../../lib/constants";

const incidents = await getIncidents();
---

<BaseLayout
  title="Incidents"
  description="Post-mortems and incident reports. Time-bound records of outages, their root causes, impact, and action items."
>
  <Navigation />

  <GridLayout class="py-8">
    <main id="main-content" class="lg:col-start-4 lg:col-span-6">
    <div class="mb-10">
      <PageBreadcrumb items={[
        { label: "Home", href: "/" },
        { label: "Incidents" },
      ]} />
      <h1 class="font-[family-name:var(--font-heading)] text-3xl sm:text-4xl font-bold text-neutral-100 mb-2 mt-3 text-balance">
        Incidents
      </h1>
      <p class="text-neutral-400">
        Post-mortems and incident reports. Time-bound records of outages, their root causes, impact, and action items.
      </p>
    </div>

    {incidents.length > 0 ? (
      <ul class="space-y-4">
        {incidents.map((entry) => (
          <li>
            <a href={`/incidents/${entry.slug}`} class="group block no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500">
              <Card className="transition-colors group-hover:ring-orange-500">
                <CardHeader>
                  <div class="flex items-center gap-3">
                    <time
                      datetime={entry.data.pubDate.toISOString()}
                      class="text-sm text-muted-foreground tabular-nums"
                    >
                      {entry.data.pubDate.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                    </time>
                    {entry.data.severity && (
                      <Badge className={SEVERITY_COLORS[entry.data.severity]}>
                        {entry.data.severity}
                      </Badge>
                    )}
                  </div>
                  <CardTitle className="text-lg group-hover:text-orange-500 transition-colors">
                    {entry.data.title}
                  </CardTitle>
                  <CardDescription>{entry.data.description}</CardDescription>
                </CardHeader>
                {entry.data.tags.length > 0 && (
                  <CardContent>
                    <div class="flex gap-1.5">
                      {entry.data.tags.map((tag: string) => (
                        <Badge variant="outline">{tag}</Badge>
                      ))}
                    </div>
                  </CardContent>
                )}
              </Card>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-sm text-neutral-500 italic">No incidents recorded yet.</p>
    )}
    </main>
  </GridLayout>
</BaseLayout>
