---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import { getIncidents } from "../../lib/collections";
import { articleJsonLd } from "../../lib/structured-data";
import TableOfContents from "../../components/TableOfContents";

export async function getStaticPaths() {
  const incidents = await getIncidents();
  return incidents.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const severityColors: Record<string, string> = {
  critical: "bg-red-900 text-red-300 border-red-700",
  major: "bg-orange-900 text-orange-300 border-orange-700",
  minor: "bg-yellow-900 text-yellow-300 border-yellow-700",
};

const jsonLd = articleJsonLd({
  title: entry.data.title,
  description: entry.data.description,
  pubDate: entry.data.pubDate,
  updatedDate: entry.data.updatedDate,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
});
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  jsonLd={jsonLd}
>
  <Navigation />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="lg:grid lg:grid-cols-[1fr_200px] lg:gap-8">
      <article class="prose prose-invert prose-zinc max-w-none">
        <header class="not-prose mb-8">
          <div class="mb-4">
            <a
              href="/incidents/"
              class="text-sm text-zinc-400 hover:text-orange-500 no-underline transition-colors"
            >
              &larr; All Incidents
            </a>
          </div>
          <h1 class="font-[family-name:var(--font-heading)] text-3xl sm:text-4xl font-bold text-zinc-100 mb-3">
            {entry.data.title}
          </h1>
          <p class="text-zinc-400 mb-4">{entry.data.description}</p>
          <div class="flex items-center gap-3 text-sm text-zinc-500">
            <time datetime={entry.data.pubDate.toISOString()}>
              {entry.data.pubDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
            {entry.data.severity && (
              <span
                class:list={[
                  "px-1.5 py-0.5 text-xs border",
                  severityColors[entry.data.severity],
                ]}
              >
                {entry.data.severity}
              </span>
            )}
            {entry.data.tags.length > 0 && (
              <div class="flex gap-1.5">
                {entry.data.tags.map((tag: string) => (
                  <span class="px-1.5 py-0.5 bg-zinc-800 border border-zinc-700 text-zinc-400 text-xs">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </header>

        <Content />
      </article>

      <aside class="hidden lg:block">
        <div class="sticky top-20">
          <TableOfContents headings={headings} client:idle />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
