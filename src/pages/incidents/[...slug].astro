---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import GridLayout from "../../components/GridLayout.astro";
import { getIncidents } from "../../lib/collections";
import { articleJsonLd } from "../../lib/structured-data";
import { PageBreadcrumb } from "../../components/PageBreadcrumb";
import TableOfContents from "../../components/TableOfContents";
import { Badge } from "../../components/ui/badge";
import { SEVERITY_COLORS } from "../../lib/constants";

export async function getStaticPaths() {
  const incidents = await getIncidents();
  return incidents.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const jsonLd = articleJsonLd({
  title: entry.data.title,
  description: entry.data.description,
  pubDate: entry.data.pubDate,
  updatedDate: entry.data.updatedDate,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
});
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  jsonLd={jsonLd}
>
  <Navigation />

  <GridLayout class="py-12">
    <main id="main-content" class="min-w-0 lg:col-start-4 lg:col-span-6">
      <article class="prose prose-invert prose-zinc max-w-none">
        <header class="not-prose mb-8">
          <PageBreadcrumb items={[
            { label: "Home", href: "/" },
            { label: "Incidents", href: "/incidents" },
            { label: entry.data.title },
          ]} />
          <h1 class="font-[family-name:var(--font-heading)] text-3xl sm:text-4xl font-bold text-zinc-100 mb-3 mt-3 text-balance">
            {entry.data.title}
          </h1>
          <p class="text-zinc-400 mb-4">{entry.data.description}</p>
          <div class="flex items-center gap-3 text-sm text-zinc-500">
            <time datetime={entry.data.pubDate.toISOString()}>
              {entry.data.pubDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
            {entry.data.severity && (
              <Badge className={SEVERITY_COLORS[entry.data.severity]}>
                {entry.data.severity}
              </Badge>
            )}
            {entry.data.tags.length > 0 && (
              <div class="flex gap-1.5">
                {entry.data.tags.map((tag: string) => (
                  <Badge variant="outline">{tag}</Badge>
                ))}
              </div>
            )}
          </div>
        </header>

        <Content />
      </article>
    </main>

      <aside class="hidden lg:block lg:col-span-3">
        <div class="sticky top-[3.75rem]">
          <TableOfContents headings={headings} client:idle />
        </div>
      </aside>
  </GridLayout>
</BaseLayout>
