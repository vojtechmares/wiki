---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import {
  CATEGORIES,
  CATEGORY_META,
  getEntriesByCategory,
  type Category,
} from "../../lib/collections";

export function getStaticPaths() {
  return CATEGORIES.map((category) => ({ params: { category } }));
}

const { category } = Astro.params as { category: Category };
const meta = CATEGORY_META[category];
const entries = await getEntriesByCategory(category);
---

<BaseLayout title={meta.label} description={meta.description}>
  <Navigation />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <h1 class="font-[family-name:var(--font-heading)] text-3xl sm:text-4xl font-bold text-zinc-100 mb-2">
        {meta.label}
      </h1>
      <p class="text-zinc-400">{meta.description}</p>
    </div>

    <ul class="space-y-4">
      {
        entries.map((entry) => (
          <li>
            <a
              href={`/${category}/${entry.id}/`}
              class="group block p-5 bg-zinc-800 border border-zinc-700 no-underline transition-colors hover:border-orange-500"
            >
              <h2 class="font-[family-name:var(--font-heading)] text-lg font-semibold text-zinc-100 mb-1 group-hover:text-orange-500 transition-colors">
                {entry.data.title}
              </h2>
              <p class="text-sm text-zinc-400 mb-2">{entry.data.description}</p>
              <div class="flex items-center gap-3 text-xs text-zinc-500">
                <time datetime={entry.data.pubDate.toISOString()}>
                  {entry.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                {entry.data.tags.length > 0 && (
                  <div class="flex gap-1.5">
                    {entry.data.tags.map((tag: string) => (
                      <span class="px-1.5 py-0.5 bg-zinc-700 text-zinc-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
