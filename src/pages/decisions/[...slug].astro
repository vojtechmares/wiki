---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import GridLayout from "../../components/GridLayout.astro";
import { getDecisions } from "../../lib/collections";
import { articleJsonLd } from "../../lib/structured-data";
import { PageBreadcrumb } from "../../components/PageBreadcrumb";
import TableOfContents from "../../components/TableOfContents";
import { Badge } from "../../components/ui/badge";
import { STATUS_COLORS } from "../../lib/constants";

export async function getStaticPaths() {
  const decisions = await getDecisions();
  return decisions.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const jsonLd = articleJsonLd({
  title: entry.data.title,
  description: entry.data.description,
  pubDate: entry.data.pubDate,
  updatedDate: entry.data.updatedDate,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
});
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  jsonLd={jsonLd}
  mdHref={`${Astro.url.pathname}.md`}
>
  <Navigation />

  <GridLayout class="py-8">
    <main id="main-content" class="min-w-0 lg:col-start-4 lg:col-span-6">
      <article class="prose prose-invert prose-neutral max-w-none">
        <header class="not-prose mb-8">
          <PageBreadcrumb items={[
            { label: "Home", href: "/" },
            { label: "Decisions", href: "/decisions" },
            { label: entry.data.title },
          ]} />
          <h1 class="font-[family-name:var(--font-heading)] text-3xl sm:text-4xl font-bold text-neutral-100 mb-3 mt-3 text-balance">
            {entry.data.title}
          </h1>
          <p class="text-neutral-400 mb-4">{entry.data.description}</p>
          <div class="flex items-center gap-3 text-sm text-neutral-500">
            <time datetime={entry.data.pubDate.toISOString()}>
              {entry.data.pubDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
            <Badge className={STATUS_COLORS[entry.data.status]}>
              {entry.data.status}
            </Badge>
            {entry.data.tags.length > 0 && (
              <div class="flex gap-1.5">
                {entry.data.tags.map((tag: string) => (
                  <Badge variant="outline">{tag}</Badge>
                ))}
              </div>
            )}
          </div>
          {entry.data.supersededBy && (
            <div class="mt-4 p-3 bg-yellow-900/30 border border-yellow-700/50 text-yellow-300 text-sm">
              This decision has been superseded by{" "}
              <a
                href={`/decisions/${entry.data.supersededBy}`}
                class="text-yellow-200 underline hover:text-orange-500"
              >
                {entry.data.supersededBy}
              </a>
            </div>
          )}
        </header>

        <Content />
      </article>
    </main>

      <aside class="hidden lg:block lg:col-span-3">
        <div class="sticky top-[3.75rem]">
          <TableOfContents headings={headings} client:idle />
        </div>
      </aside>
  </GridLayout>
</BaseLayout>
