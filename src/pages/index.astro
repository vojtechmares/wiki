---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import { DOMAINS, DOMAIN_META, getEntriesByDomain, getIncidents, getDecisions } from "../lib/collections";
import { websiteJsonLd } from "../lib/structured-data";

const jsonLd = websiteJsonLd({
  url: Astro.site?.toString() || "",
  name: "DevOps Wiki",
});

const incidents = await getIncidents();
const decisions = await getDecisions();

const domainsWithCount = await Promise.all(
  DOMAINS.map(async (domain) => {
    const entries = await getEntriesByDomain(domain);
    return { domain, ...DOMAIN_META[domain], count: entries.length };
  })
);
---

<BaseLayout
  title="Home"
  description="A knowledge base for DevOps and Platform engineers. Tutorials, how-to guides, explanations, and references."
  jsonLd={jsonLd}
>
  <Navigation />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-16">
      <h1 class="font-[family-name:var(--font-heading)] text-4xl sm:text-5xl font-bold text-zinc-100 mb-4">
        DevOps Wiki
      </h1>
      <p class="text-lg text-zinc-300 max-w-2xl">
        A knowledge base for DevOps and Platform engineers. Find tutorials, practical guides, deep explanations, and quick reference material.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {
        domainsWithCount.map(({ domain, label, description, count }) => (
          <a
            href={`/${domain}/`}
            class="group block p-6 bg-zinc-800 border border-zinc-700 no-underline transition-colors hover:border-orange-500"
          >
            <h2 class="font-[family-name:var(--font-heading)] text-xl font-semibold text-zinc-100 mb-2 group-hover:text-orange-500 transition-colors">
              {label}
            </h2>
            <p class="text-sm text-zinc-400 mb-3">{description}</p>
            <span class="text-xs text-zinc-500">{count} {count === 1 ? "article" : "articles"}</span>
          </a>
        ))
      }
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-12">
      <a
        href="/incidents/"
        class="group block p-6 bg-zinc-800 border border-zinc-700 no-underline transition-colors hover:border-orange-500"
      >
        <h2 class="font-[family-name:var(--font-heading)] text-xl font-semibold text-zinc-100 mb-2 group-hover:text-orange-500 transition-colors">
          Incidents
        </h2>
        <p class="text-sm text-zinc-400 mb-3">Post-mortems, root cause analysis, and action items from production incidents.</p>
        <span class="text-xs text-zinc-500">{incidents.length} {incidents.length === 1 ? "incident" : "incidents"}</span>
      </a>
      <a
        href="/decisions/"
        class="group block p-6 bg-zinc-800 border border-zinc-700 no-underline transition-colors hover:border-orange-500"
      >
        <h2 class="font-[family-name:var(--font-heading)] text-xl font-semibold text-zinc-100 mb-2 group-hover:text-orange-500 transition-colors">
          Decisions
        </h2>
        <p class="text-sm text-zinc-400 mb-3">Architecture Decision Records capturing why choices were made and their consequences.</p>
        <span class="text-xs text-zinc-500">{decisions.length} {decisions.length === 1 ? "decision" : "decisions"}</span>
      </a>
    </div>
  </main>
</BaseLayout>
