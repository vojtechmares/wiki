---
import { render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Navigation from "../../../components/Navigation.astro";
import ContentLayout from "../../../components/ContentLayout.astro";
import { getAllEntries, DOMAIN_META, FORMAT_META, type Domain, type Format } from "../../../lib/collections";
import { articleJsonLd } from "../../../lib/structured-data";
import { PageBreadcrumb } from "../../../components/PageBreadcrumb";
import { Badge } from "../../../components/ui/badge";

export async function getStaticPaths() {
  const entries = await getAllEntries();
  return entries.map((entry) => ({
    params: { domain: entry.domain, format: entry.format, slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const ogImage = new URL(
  `/og/${entry.domain}/${entry.format}/${entry.slug}.png`,
  Astro.site
).toString();

const jsonLd = articleJsonLd({
  title: entry.data.title,
  description: entry.data.description,
  pubDate: entry.data.pubDate,
  updatedDate: entry.data.updatedDate,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
});
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <Navigation />

  <ContentLayout
    domain={entry.domain as Domain}
    format={entry.format as Format}
    currentSlug={entry.slug}
    headings={headings}
  >
    <header class="not-prose mb-8">
      <PageBreadcrumb items={[
        { label: "Home", href: "/" },
        { label: DOMAIN_META[entry.domain as Domain].label, href: `/${entry.domain}` },
        { label: FORMAT_META[entry.format as Format].label, href: `/${entry.domain}/${entry.format}` },
        { label: entry.data.title },
      ]} />
      <h1 class="font-[family-name:var(--font-heading)] text-3xl sm:text-4xl font-bold text-zinc-100 mb-3 mt-3 text-balance">
        {entry.data.title}
      </h1>
      <p class="text-zinc-400 mb-4">{entry.data.description}</p>
      <div class="flex items-center gap-3 text-sm text-zinc-500">
        <time datetime={entry.data.pubDate.toISOString()}>
          {entry.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {
          entry.data.tags.length > 0 && (
            <div class="flex gap-1.5">
              {entry.data.tags.map((tag: string) => (
                <Badge variant="outline">{tag}</Badge>
              ))}
            </div>
          )
        }
      </div>
    </header>

    <Content />
  </ContentLayout>
</BaseLayout>
