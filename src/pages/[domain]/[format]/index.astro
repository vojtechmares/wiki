---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Navigation from "../../../components/Navigation.astro";
import GridLayout from "../../../components/GridLayout.astro";
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "../../../components/ui/card";
import { Badge } from "../../../components/ui/badge";
import { PageBreadcrumb } from "../../../components/PageBreadcrumb";
import {
  DOMAINS,
  DOMAIN_META,
  FORMATS,
  FORMAT_META,
  getEntriesByDomainAndFormat,
  type Domain,
  type Format,
} from "../../../lib/collections";

export function getStaticPaths() {
  return DOMAINS.flatMap((domain) =>
    FORMATS.map((format) => ({ params: { domain, format } }))
  );
}

const { domain, format } = Astro.params as { domain: Domain; format: Format };
const domainMeta = DOMAIN_META[domain];
const formatMeta = FORMAT_META[format];
const entries = await getEntriesByDomainAndFormat(domain, format);
---

<BaseLayout
  title={`${formatMeta.label} — ${domainMeta.label}`}
  description={`${formatMeta.description} for ${domainMeta.label.toLowerCase()}.`}
>
  <Navigation />

  <GridLayout class="py-12">
    <main id="main-content" class="lg:col-start-4 lg:col-span-6">
    <div class="mb-10">
      <PageBreadcrumb items={[
        { label: "Home", href: "/" },
        { label: domainMeta.label, href: `/${domain}` },
        { label: formatMeta.label },
      ]} />
      <h1 class="font-[family-name:var(--font-heading)] text-3xl sm:text-4xl font-bold text-zinc-100 mb-2 mt-3 text-balance">
        {formatMeta.label}
      </h1>
      <p class="text-zinc-400">{formatMeta.description}</p>
    </div>

    {entries.length > 0 ? (
      <ul class="space-y-4">
        {entries.map((entry) => (
          <li>
            <a href={`/${domain}/${entry.format}/${entry.slug}`} class="group block no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500">
              <Card className="transition-colors group-hover:ring-orange-500">
                <CardHeader>
                  <CardTitle className="text-lg group-hover:text-orange-500 transition-colors">
                    {entry.data.title}
                  </CardTitle>
                  <CardDescription>{entry.data.description}</CardDescription>
                </CardHeader>
                <CardContent>
                  <div class="flex items-center gap-3 text-xs text-muted-foreground">
                    <time datetime={entry.data.pubDate.toISOString()}>
                      {entry.data.pubDate.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      })}
                    </time>
                    {entry.data.tags.length > 0 && (
                      <div class="flex gap-1.5">
                        {entry.data.tags.map((tag: string) => (
                          <Badge variant="outline">{tag}</Badge>
                        ))}
                      </div>
                    )}
                  </div>
                </CardContent>
              </Card>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-zinc-500 italic">No articles yet. Check back soon.</p>
    )}
    </main>
  </GridLayout>
</BaseLayout>
