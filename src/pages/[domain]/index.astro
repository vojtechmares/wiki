---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import GridLayout from "../../components/GridLayout.astro";
import { Card, CardHeader, CardTitle, CardDescription } from "../../components/ui/card";
import {
  DOMAINS,
  DOMAIN_META,
  FORMATS,
  FORMAT_META,
  getEntriesByDomain,
  getDecisionsByTag,
  type Domain,
} from "../../lib/collections";

export function getStaticPaths() {
  return DOMAINS.map((domain) => ({ params: { domain } }));
}

const { domain } = Astro.params as { domain: Domain };
const meta = DOMAIN_META[domain];
const entries = await getEntriesByDomain(domain);

const relatedDecisions = await getDecisionsByTag(domain);

const entriesByFormat = FORMATS.map((format) => ({
  format,
  ...FORMAT_META[format],
  entries: entries.filter((e) => e.format === format),
}));
---

<BaseLayout title={meta.label} description={meta.description}>
  <Navigation />

  <GridLayout class="py-12">
    <main class="lg:col-start-4 lg:col-span-6">
    <div class="mb-10">
      <h1 class="font-[family-name:var(--font-heading)] text-3xl sm:text-4xl font-bold text-zinc-100 mb-2">
        {meta.label}
      </h1>
      <p class="text-zinc-400">{meta.description}</p>
    </div>

    {
      entriesByFormat.map(({ format, label, description, entries }) => (
        <section class="mb-10">
          <div class="flex items-baseline justify-between mb-4">
            <h2 class="font-[family-name:var(--font-heading)] text-xl font-semibold text-zinc-200">
              {label}
            </h2>
            {entries.length > 0 && (
              <a
                href={`/${domain}/${format}`}
                class="text-sm text-zinc-400 hover:text-orange-500 no-underline transition-colors"
              >
                View all
              </a>
            )}
          </div>
          {entries.length > 0 ? (
            <ul class="space-y-3">
              {entries.map((entry) => (
                <li>
                  <a href={`/${domain}/${entry.format}/${entry.slug}`} class="group block no-underline">
                    <Card size="sm" className="transition-colors group-hover:ring-orange-500">
                      <CardHeader>
                        <CardTitle className="group-hover:text-orange-500 transition-colors">
                          {entry.data.title}
                        </CardTitle>
                        <CardDescription>{entry.data.description}</CardDescription>
                      </CardHeader>
                    </Card>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-zinc-500 italic">{description} &mdash; coming soon.</p>
          )}
        </section>
      ))
    }

    {relatedDecisions.length > 0 && (
      <section class="mb-10">
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="font-[family-name:var(--font-heading)] text-xl font-semibold text-zinc-200">
            Related Decisions
          </h2>
          <a
            href={`/${domain}/decisions`}
            class="text-sm text-zinc-400 hover:text-orange-500 no-underline transition-colors"
          >
            View all
          </a>
        </div>
        <ul class="space-y-3">
          {relatedDecisions.map((entry) => (
            <li>
              <a href={`/decisions/${entry.slug}`} class="group block no-underline">
                <Card size="sm" className="transition-colors group-hover:ring-orange-500">
                  <CardHeader>
                    <CardTitle className="group-hover:text-orange-500 transition-colors">
                      {entry.data.title}
                    </CardTitle>
                    <CardDescription>{entry.data.description}</CardDescription>
                  </CardHeader>
                </Card>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
    </main>
  </GridLayout>
</BaseLayout>
