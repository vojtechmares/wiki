---
import {
  getEntriesByDomain,
  FORMATS,
  FORMAT_META,
  type Domain,
  type Format,
} from "../lib/collections";

interface Props {
  domain: Domain;
  currentFormat?: Format;
  currentSlug?: string;
}

const {domain, currentFormat, currentSlug} = Astro.props;
const entries = await getEntriesByDomain(domain);

const entriesByFormat = FORMATS.map((format) => ({
  format,
  entries: entries.filter((e) => e.format === format),
})).filter(({entries}) => entries.length > 0);
---

<aside class="hidden lg:block lg:col-span-3">
  <div
    class="sticky top-[3.75rem] h-[calc(100vh-3.75rem)] overflow-y-auto py-6 pr-4"
  >
    {
      entriesByFormat.map(({format, entries}) => (
        <div class="mb-5">
          <h2 class="font-[family-name:var(--font-heading)] font-semibold text-xs text-zinc-400 uppercase tracking-wider mb-2">
            {FORMAT_META[format].label}
          </h2>
          <ul class="space-y-0.5">
            {entries.map((entry) => {
              const isActive =
                entry.format === currentFormat && entry.slug === currentSlug;
              return (
                <li>
                  <a
                    href={`/${domain}/${entry.format}/${entry.slug}/`}
                    class:list={[
                      "block px-3 py-1.5 text-sm no-underline transition-colors",
                      isActive
                        ? "text-orange-500 bg-zinc-800 border-l-2 border-orange-500"
                        : "text-zinc-300 hover:text-zinc-100 hover:bg-zinc-800 border-l-2 border-transparent",
                    ]}
                  >
                    {entry.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </div>
</aside>
