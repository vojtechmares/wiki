---
import { DOMAINS, DOMAIN_META } from "../lib/collections";

const currentYear = new Date().getFullYear();
---

<footer class="bg-neutral-800 border-t border-neutral-700 mt-auto">
  <div class="mx-auto px-4 md:px-6 lg:px-8 xl:px-10 max-w-[1280px]">
    <div class="grid grid-cols-1 gap-y-6 pb-16 pt-12 sm:pb-24 sm:pt-16 lg:grid-cols-4 lg:gap-4">
      <div>
        <h3 class="text-[1.75rem] font-[family-name:var(--font-heading)] font-semibold leading-[1.3] tracking-tight text-neutral-100">
          DevOps Wiki
        </h3>
        <p class="mt-4 text-sm text-neutral-400">
          A knowledge base for DevOps and Platform engineers. Tutorials, practical guides, deep explanations, and quick reference material.
        </p>
      </div>

      <div>
        <h3 class="text-[1.75rem] font-[family-name:var(--font-heading)] font-semibold leading-[1.3] tracking-tight text-neutral-100">
          Domains
        </h3>
        <ul class="mt-4 list-none space-y-1">
          {DOMAINS.map((domain) => (
            <li>
              <span class="text-neutral-500 mr-1">&rarr;</span>
              <a
                href={`/${domain}`}
                class="text-orange-500 underline hover:text-orange-300 transition-colors"
              >
                {DOMAIN_META[domain].label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-[1.75rem] font-[family-name:var(--font-heading)] font-semibold leading-[1.3] tracking-tight text-neutral-100">
          Resources
        </h3>
        <ul class="mt-4 list-none space-y-1">
          <li>
            <span class="text-neutral-500 mr-1">&rarr;</span>
            <a href="/incidents" class="text-orange-500 underline hover:text-orange-300 transition-colors">Incidents</a>
          </li>
          <li>
            <span class="text-neutral-500 mr-1">&rarr;</span>
            <a href="/decisions" class="text-orange-500 underline hover:text-orange-300 transition-colors">Decisions</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-[1.75rem] font-[family-name:var(--font-heading)] font-semibold leading-[1.3] tracking-tight text-neutral-100">
          About
        </h3>
        <p class="mt-4 text-sm text-neutral-400">
          Built as an internal knowledge base following the Diataxis documentation framework. Organized by domain and format to help you find the right content fast.
        </p>
      </div>
    </div>

    <div class="flex flex-col items-center border-t border-neutral-700 py-10 md:flex-row-reverse md:justify-between">
      <div class="flex gap-x-6">
        <a href="https://github.com/vojtechmares/wiki" target="_blank" rel="noreferrer" class="group" aria-label="GitHub">
          <svg aria-hidden="true" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 fill-neutral-400 group-hover:fill-neutral-200 transition-colors">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path>
          </svg>
        </a>
      </div>
      <p class="text-sm text-neutral-500 mt-6 md:mt-0">
        Copyright &copy; {currentYear} Vojtěch Mareš. All rights reserved.
      </p>
    </div>
  </div>
</footer>
