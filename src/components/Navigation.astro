---
import { DOMAINS, DOMAIN_META } from "../lib/collections";
import Search from "./Search";

const pathname = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-zinc-900 border-b border-zinc-700">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a
        href="/"
        class="text-zinc-100 font-[family-name:var(--font-heading)] font-bold text-lg no-underline hover:text-orange-500 transition-colors"
      >
        DevOps Wiki
      </a>

      <div class="hidden md:flex items-center gap-1">
        {
          DOMAINS.map((domain) => {
            const isActive = pathname.startsWith(`/${domain}`);
            return (
              <a
                href={`/${domain}/`}
                class:list={[
                  "px-3 py-1.5 text-sm no-underline transition-colors",
                  isActive
                    ? "text-orange-500 bg-zinc-800"
                    : "text-zinc-300 hover:text-zinc-100 hover:bg-zinc-800",
                ]}
              >
                {DOMAIN_META[domain].label}
              </a>
            );
          })
        }
        <span class="w-px h-4 bg-zinc-700 mx-1"></span>
        <a
          href="/incidents/"
          class:list={[
            "px-3 py-1.5 text-sm no-underline transition-colors",
            pathname.startsWith("/incidents")
              ? "text-orange-500 bg-zinc-800"
              : "text-zinc-300 hover:text-zinc-100 hover:bg-zinc-800",
          ]}
        >
          Incidents
        </a>
        <a
          href="/decisions/"
          class:list={[
            "px-3 py-1.5 text-sm no-underline transition-colors",
            pathname.startsWith("/decisions")
              ? "text-orange-500 bg-zinc-800"
              : "text-zinc-300 hover:text-zinc-100 hover:bg-zinc-800",
          ]}
        >
          Decisions
        </a>
        <span class="w-px h-4 bg-zinc-700 mx-1"></span>
        <Search client:idle />
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-zinc-300 hover:text-zinc-100 p-2"
        aria-label="Toggle navigation"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-3 border-t border-zinc-800">
      <div class="px-3 py-2">
        <Search client:idle />
      </div>
      {
        DOMAINS.map((domain) => {
          const isActive = pathname.startsWith(`/${domain}`);
          return (
            <a
              href={`/${domain}/`}
              class:list={[
                "block px-3 py-2 text-sm no-underline",
                isActive
                  ? "text-orange-500 bg-zinc-800"
                  : "text-zinc-300 hover:text-zinc-100",
              ]}
            >
              {DOMAIN_META[domain].label}
            </a>
          );
        })
      }
      <div class="border-t border-zinc-800 mt-1 pt-1">
        <a
          href="/incidents/"
          class:list={[
            "block px-3 py-2 text-sm no-underline",
            pathname.startsWith("/incidents")
              ? "text-orange-500 bg-zinc-800"
              : "text-zinc-300 hover:text-zinc-100",
          ]}
        >
          Incidents
        </a>
        <a
          href="/decisions/"
          class:list={[
            "block px-3 py-2 text-sm no-underline",
            pathname.startsWith("/decisions")
              ? "text-orange-500 bg-zinc-800"
              : "text-zinc-300 hover:text-zinc-100",
          ]}
        >
          Decisions
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
