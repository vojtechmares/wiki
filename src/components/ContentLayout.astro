---
import type { Category } from "../lib/collections";
import LeftSidebar from "./LeftSidebar.astro";
import TableOfContents from "./TableOfContents.tsx";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  category: Category;
  currentSlug: string;
  headings: Heading[];
}

const { category, currentSlug, headings } = Astro.props;
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="flex min-h-[calc(100vh-3.5rem)]">
    <LeftSidebar category={category} currentSlug={currentSlug} />

    <main class="flex-1 min-w-0 py-8 lg:px-8">
      <article class="prose prose-lg max-w-none">
        <slot />
      </article>
    </main>

    <TableOfContents headings={headings} client:idle />
  </div>
</div>
