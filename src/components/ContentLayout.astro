---
import type {Domain, Format} from "../lib/collections";
import GridLayout from "./GridLayout.astro";
import LeftSidebar from "./LeftSidebar.astro";
import TableOfContents from "./TableOfContents.tsx";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  domain: Domain;
  format: Format;
  currentSlug: string;
  headings: Heading[];
}

const {domain, format, currentSlug, headings} = Astro.props;
---

<GridLayout class="min-h-[calc(100vh-3.5rem)]">
  <LeftSidebar
    domain={domain}
    currentFormat={format}
    currentSlug={currentSlug}
  />

  <main id="main-content" class="min-w-0 py-8 lg:col-span-6">
    <article class="prose prose-lg max-w-none">
      <slot />
    </article>
  </main>

  <TableOfContents headings={headings} client:idle />
</GridLayout>
